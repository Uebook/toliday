<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Clear any globally registered iisnode handler to avoid naming conflicts -->
      <remove name="iisnode" />
      <!-- Indicates that the startup file is a node.js site to be handled by the iisnode module -->
      <add name="iisnode" path="dist/src/main.js" verb="*" modules="iisnode" />
    </handlers>
    <iisnode environmentVariables="DB_HOST=161.248.26.53;NODE_ENV=production" />
    <rewrite>
      <rules>
        <!-- Route all requests to the startup file -->
        <rule name="TolidayBackendDynamicContent">
          <match url=".*" />
          <conditions>
            <!-- Do not rewrite requests for existing files (like sqlite DB or uploads) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="dist/src/main.js" />
        </rule>
      </rules>
      <outboundRules>
        <rule name="AddCORSHeader" preCondition="NotOptions">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern=".*" />
          <conditions>
            <add input="{HTTP_ORIGIN}" pattern="^https?://(tolidaytrip\.com|www\.tolidaytrip\.com|portal\.tolidaytrip\.com|localhost:\d+)$" />
          </conditions>
          <action type="Rewrite" value="{HTTP_ORIGIN}" />
        </rule>
        <rule name="AddCORSAllowMethods">
          <match serverVariable="RESPONSE_Access_Control_Allow_Methods" pattern=".*" />
          <action type="Rewrite" value="GET, POST, PUT, PATCH, DELETE, OPTIONS" />
        </rule>
        <rule name="AddCORSAllowHeaders">
          <match serverVariable="RESPONSE_Access_Control_Allow_Headers" pattern=".*" />
          <action type="Rewrite" value="Content-Type, Authorization, Accept" />
        </rule>
        <rule name="AddCORSAllowCredentials">
          <match serverVariable="RESPONSE_Access_Control_Allow_Credentials" pattern=".*" />
          <action type="Rewrite" value="true" />
        </rule>
        <preConditions>
          <preCondition name="NotOptions">
            <add input="{REQUEST_METHOD}" pattern="OPTIONS" negate="true" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
