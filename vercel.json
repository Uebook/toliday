{
       "version": 2,
       "rewrites": [
              {
                     "source": "/api/test-db",
                     "destination": "backend/api/test-db.ts"
              },
              {
                     "source": "/api/(.*)",
                     "destination": "backend/api/index.ts"
              },
              {
                     "source": "/((?!api/).*)",
                     "destination": "frontend/$1"
              }
       ],
       "builds": [
              {
                     "src": "frontend/package.json",
                     "use": "@vercel/next"
              },
              {
                     "src": "backend/api/*.ts",
                     "use": "@vercel/node",
                     "config": {
                            "includeFiles": "backend/certs/**"
                     }
              }
       ]
}